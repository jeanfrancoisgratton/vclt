post_install() {
    # Bash completion — always install
    if [ -d /etc/bash_completion.d ]; then
        /opt/bin/vclt completion bash > /etc/bash_completion.d/vclt
    fi

    # Zsh completion — only if zsh is present
    if command -v zsh > /dev/null 2>&1; then
        mkdir -p /usr/share/zsh/site-functions
        /opt/bin/vclt completion zsh > /usr/share/zsh/site-functions/_vclt
        # Rebuild zsh completion cache for all users
        zsh -c 'autoload -Uz compinit && compinit' 2>/dev/null || true
    fi
}

post_upgrade() {
    post_install
}

post_remove() {
    rm -f /etc/bash_completion.d/vclt
    rm -f /usr/share/zsh/site-functions/_vclt
}
