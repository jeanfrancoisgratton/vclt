# Maintainer: J.F.Gratton <jean-francois@famillegratton.net>
# Packager: Package builder <builder@famillegratton.net>

pkgname=vclt
pkgver=2.3.0
pkgrel=1
pkgdesc="Hashicorp Vault client"
arch=('x86_64')
url="https://git.famillegratton.net:3000/devops/vclt.git"
license=('GPL-2.0-only')

makedepends=('go')
depends=('bash-completion')

optdepends=('zsh: zsh completion support')

options=('!debug')

_binaryname='vclt'
_builddir="${pkgname}-${pkgver}"

install=vclt.install

prepare() {
  rm -rf "${srcdir:?}/${_builddir}"
  mkdir -p "${srcdir}/${_builddir}"

  cp -a "${startdir}/../src/." "${srcdir}/${_builddir}/"
}

build() {
  cd "${srcdir}/${_builddir}"

  export CGO_ENABLED=0
  export GOPATH="${srcdir}/gopath"
  export GOMODCACHE="${GOPATH}/pkg/mod"

  go build -trimpath -mod=readonly -modcacherw -ldflags="-s -w -buildid=" -o "${_binaryname}" .
}

check() {
  cd "${srcdir}/${_builddir}"
  go test -modcacherw ./...
}

package() {
  cd "${srcdir}/${_builddir}"

  install -Dm0755 "${_binaryname}" "${pkgdir}/opt/bin/${_binaryname}"
}
