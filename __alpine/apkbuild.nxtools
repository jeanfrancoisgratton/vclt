# Maintainer: J.F.Gratton <jean-francois@famillegratton.net>
# Packager: Package builder <builder@famillegratton.net>
pkgname=nxtools
pkgver=0.91.00_pre
pkgrel=0
pkgdir=/data/packages
pkgdesc="Nexus Repository Manager tools"
url="https://git.famillegratton.net:3000/devops/nxtools.git"
arch=x86_64
license=GPL2
#depends="gcompat"
install="$pkgname.pre-deinstall $pkgname.post-install"
#source="$pkgname-$pkgver-$pkgrel.tar.bz2::http://localhost/$pkgname-$pkgver-$pkgrel.tar.bz2"
builddir="$startdir/src/BUILD"

binaryname=nxtools

prepare() {
	mkdir -p "$builddir"
	cp -R "$startdir"/../src/* "$builddir"/
}

build() {
	cd "$builddir"

	go env | egrep 'GOFLAGS|CGO_ENABLED|GOOS|GOARCH' || true

	# Static, non-PIE, internal linker
	CGO_ENABLED=0 go build -trimpath -ldflags="-s -w -buildid= -linkmode=internal" -o "$binaryname" .
}

package() {
	install -d "$pkgdir"/opt/bin
	install -m755 "$builddir/$binaryname" "$pkgdir/opt/bin/$binaryname"
}
